<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WordKing" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/charcoal_blue</item>
        <item name="android:navigationBarColor">@color/background</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Surface -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
    </style>

    <!-- Button styles -->
    <style name="Widget.WordKing.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/on_primary</item>
        <item name="backgroundTint">@color/verdigris</item>
    </style>

    <style name="Widget.WordKing.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/verdigris</item>
        <item name="android:textColor">@color/verdigris</item>
    </style>

    <style name="Widget.WordKing.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/tuscan_sun</item>
        <item name="android:textColor">@color/charcoal_blue</item>
    </style>

    <!-- Card styles -->
    <style name="Widget.WordKing.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.WordKing.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/charcoal_blue</item>
    </style>

    <style name="TextAppearance.WordKing.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/charcoal_blue</item>
    </style>

    <style name="TextAppearance.WordKing.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/charcoal_blue</item>
    </style>

    <style name="TextAppearance.WordKing.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
